          <pre id="sql-code">-- Cole no SQL Editor do Supabase → Run
CREATE TABLE IF NOT EXISTS profiles (
  id UUID REFERENCES auth.users(id) ON DELETE CASCADE PRIMARY KEY,
  email TEXT,
  subscription_status TEXT DEFAULT 'trial',
  trial_started_at TIMESTAMPTZ DEFAULT NOW(),
  subscription_expires_at TIMESTAMPTZ,
  plans_generated INT DEFAULT 0,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS plans (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  user_id UUID REFERENCES profiles(id) ON DELETE CASCADE,
  answers JSONB,
  plan_content TEXT,
  exam_type TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;
ALTER TABLE plans ENABLE ROW LEVEL SECURITY;

CREATE POLICY "own_profile" ON profiles FOR ALL USING (auth.uid() = id);
CREATE POLICY "own_plans"   ON plans   FOR ALL USING (auth.uid() = user_id);
CREATE POLICY "ins_profile" ON profiles FOR INSERT WITH CHECK (auth.uid() = id);
CREATE POLICY "ins_plan"    ON plans    FOR INSERT WITH CHECK (auth.uid() = user_id);</pre>
