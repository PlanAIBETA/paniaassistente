<script>
/* ── STATE ── */
const state = {
  sburl:'', sbanon:'', admin:'', apikey:'',
  cakto:'', wa:'', pass:'',
  mainGenerated: false, adminGenerated: false,
  mainContent: '', adminContent: '',
};

/* ── SECTION TOGGLE ── */
function toggleSec(n) {
  const body = document.getElementById('sb-'+n);
  body.classList.toggle('open');
}
function openSec(n) { document.getElementById('sb-'+n).classList.add('open') }
function closeSec(n) { document.getElementById('sb-'+n).classList.remove('open') }

function goSection(n) {
  // Close all
  [1,2,3,4,5,6].forEach(i => closeSec(i));
  openSec(n);
  document.getElementById('sec-'+n).scrollIntoView({behavior:'smooth', block:'start'});
}

function nextSec(current) {
  if (!validateSection(current)) return;
  markDone(current);
  if (current < 6) {
    closeSec(current);
    openSec(current+1);
    document.getElementById('sec-'+(current+1)).scrollIntoView({behavior:'smooth',block:'start'});
    activateDot(current+1);
    setActiveSection(current+1);
  }
  if (current === 5) {
    updateSummary();
  }
}

function setActiveSection(n) {
  [1,2,3,4,5,6].forEach(i => {
    const s = document.getElementById('sec-'+i);
    if (s) s.classList.remove('active');
  });
  const el = document.getElementById('sec-'+n);
  if (el) el.classList.add('active');
}

function markDone(n) {
  const num = document.getElementById('sn-'+n);
  if (num) { num.className='sec-num done'; num.textContent = n === 6 ? '✓' : '✓' }
  const sec = document.getElementById('sec-'+n);
  if (sec) sec.classList.add('done-card');
  const ss = document.getElementById('ss-'+n);
  if (ss) { ss.className='sec-status st-ok'; ss.textContent='✓ Configurado' }
  activateDot(n, true);
  if (n < 6) activateLineDone(n);
}

function activateDot(n, done=false) {
  [1,2,3,4,5,6].forEach(i => {
    const d = document.getElementById('pd-'+i);
    if (!d) return;
    if (i < n || done && i === n) d.className='step-dot done';
    else if (i === n && !done) d.className='step-dot active';
    else if (!d.classList.contains('done')) d.className='step-dot idle';
  });
}

function activateLineDone(n) {
  const l = document.getElementById('pl-'+n);
  if (l) l.classList.add('done');
}

/* ── VALIDATE SECTION ── */
function validateSection(n) {
  if (n === 1) {
    const url   = document.getElementById('f-sburl').value.trim();
    const anon  = document.getElementById('f-sbanon').value.trim();
    const admin = document.getElementById('f-admin').value.trim();
    if (!url || !url.startsWith('https://')) { showToast('⚠️ URL do Supabase inválida'); return false }
    if (!anon || !anon.startsWith('eyJ'))    { showToast('⚠️ Chave anon inválida'); return false }
    if (!admin || !admin.includes('@'))      { showToast('⚠️ E-mail do admin inválido'); return false }
    state.sburl = url; state.sbanon = anon; state.admin = admin;
    return true;
  }
  if (n === 2) {
    const key = document.getElementById('f-apikey').value.trim();
    if (!key || !key.startsWith('sk-ant')) { showToast('⚠️ Chave Anthropic inválida'); return false }
    state.apikey = key;
    return true;
  }
  if (n === 3) {
    const cakto = document.getElementById('f-cakto').value.trim();
    state.cakto = cakto || 'https://pay.cakto.com.br/SEU-LINK';
    return true;
  }
  if (n === 4) {
    const wa = document.getElementById('f-wa').value.trim().replace(/\D/g,'');
    if (!wa || wa.length < 12) { showToast('⚠️ Número de WhatsApp inválido. Formato: 5553999887766'); return false }
    state.wa = wa;
    return true;
  }
  if (n === 5) {
    const p1 = document.getElementById('f-pass1').value;
    const p2 = document.getElementById('f-pass2').value;
    if (!p1 || p1.length < 8) { showToast('⚠️ Senha deve ter pelo menos 8 caracteres'); return false }
    if (p1 !== p2) { showToast('⚠️ Senhas não conferem'); return false }
    state.pass = p1;
    return true;
  }
  return true;
}

/* ── FIELD VALIDATION ── */
function validateField(el, type) {
  const v = el.value.trim();
  el.classList.remove('ok','err-field');
  const tr = document.getElementById('tr-'+type);

  if (type === 'sburl') {
    if (v && v.startsWith('https://') && v.includes('supabase.co')) {
      el.classList.add('ok');
    } else if (v) { el.classList.add('err-field') }
  }
  if (type === 'sbanon') {
    if (v && v.startsWith('eyJ') && v.length > 100) el.classList.add('ok');
    else if (v) el.classList.add('err-field');
  }
  if (type === 'admin') {
    if (v && v.includes('@') && v.includes('.')) el.classList.add('ok');
    else if (v) el.classList.add('err-field');
  }
  if (type === 'apikey') {
    if (v && v.startsWith('sk-ant')) el.classList.add('ok');
    else if (v) el.classList.add('err-field');
  }
  if (type === 'wa') {
    const digits = v.replace(/\D/g,'');
    if (digits.length >= 12 && digits.startsWith('55')) {
      el.classList.add('ok');
      if (tr) { tr.className='test-result test-ok show'; tr.textContent='✓ Número válido: +'+digits }
    } else if (digits.length > 5) {
      el.classList.add('err-field');
      if (tr) { tr.className='test-result test-err show'; tr.textContent='Formato: 55 + DDD + número (ex: 5553999887766)' }
    } else { if (tr) tr.classList.remove('show') }
  }
  if (type === 'pass1') {
    if (v.length >= 8) el.classList.add('ok');
    else if (v) el.classList.add('err-field');
  }
  if (type === 'pass2') {
    const p1 = document.getElementById('f-pass1').value;
    const tr2 = document.getElementById('tr-pass');
    if (v && v === p1) {
      el.classList.add('ok');
      if (tr2) { tr2.className='test-result test-ok show'; tr2.textContent='✓ Senhas conferem!' }
    } else if (v) {
      el.classList.add('err-field');
      if (tr2) { tr2.className='test-result test-err show'; tr2.textContent='Senhas não conferem.' }
    } else { if (tr2) tr2.classList.remove('show') }
  }
}

/* ── TEST SUPABASE ── */
async function testSupabase() {
  const url   = document.getElementById('f-sburl').value.trim();
  const anon  = document.getElementById('f-sbanon').value.trim();
  const tr    = document.getElementById('tr-sb');
  if (!url || !anon) { tr.className='test-result test-err show'; tr.textContent='Preencha URL e chave antes de testar.'; return }
  tr.className='test-result test-ok show'; tr.innerHTML='<span class="spinner"></span> Testando conexão…';
  try {
    const res = await fetch(url+'/rest/v1/', { headers:{'apikey':anon,'Authorization':'Bearer '+anon} });
    if (res.ok || res.status === 200) {
      tr.className='test-result test-ok show'; tr.textContent='✅ Conexão com Supabase bem-sucedida! Chaves válidas.';
    } else {
      tr.className='test-result test-err show'; tr.textContent='❌ Erro '+res.status+': Verifique a URL e a chave anon.';
    }
  } catch(e) {
    tr.className='test-result test-ok show'; tr.textContent='⚠️ Não foi possível testar pelo navegador (bloqueio CORS). Continue mesmo assim — as chaves serão validadas ao abrir o site.';
  }
}

/* ── TEST ANTHROPIC ── */
function testAnthropicKey() {
  const key = document.getElementById('f-apikey').value.trim();
  const tr  = document.getElementById('tr-api');
  if (!key) { tr.className='test-result test-err show'; tr.textContent='Preencha a chave antes de verificar.'; return }
  if (key.startsWith('sk-ant')) {
    tr.className='test-result test-ok show'; tr.textContent='✅ Formato correto! Chave começa com sk-ant — parece válida.';
  } else {
    tr.className='test-result test-err show'; tr.textContent='❌ Formato inválido. A chave deve começar com sk-ant-';
  }
}

/* ── SUMMARY ── */
function updateSummary() {
  const items = [
    { icon:'🗄️', label:'Supabase URL', val: state.sburl.split('.')[0].replace('https://','')+'…', ok:!!state.sburl },
    { icon:'🔑', label:'Chave anon', val: state.sbanon.slice(0,20)+'…', ok:!!state.sbanon },
    { icon:'👤', label:'Admin', val: state.admin, ok:!!state.admin },
    { icon:'🤖', label:'Anthropic API', val: state.apikey.slice(0,15)+'…', ok:!!state.apikey },
    { icon:'💳', label:'Cakto', val: state.cakto.includes('SEU-LINK')?'Não configurado':state.cakto.split('/').pop(), ok:!state.cakto.includes('SEU-LINK') },
    { icon:'📱', label:'WhatsApp', val: '+'+state.wa, ok:!!state.wa },
    { icon:'🔐', label:'Senha admin', val: '••••••••', ok:!!state.pass },
  ];
  document.getElementById('summary').innerHTML = items.map(i=>`
    <div style="display:flex;align-items:center;gap:8px;font-size:12px">
      <span>${i.icon}</span>
      <span style="color:var(--muted);min-width:110px">${i.label}:</span>
      <span style="font-family:var(--M);color:var(--ink2);flex:1">${i.val}</span>
      <span>${i.ok?'<span class="tag tag-green">✓</span>':'<span class="tag" style="background:var(--rbg);color:var(--red);border:1px solid var(--rbd)">—</span>'}</span>
    </div>
  `).join('');
}

/* ── SELECT FILE ── */
function selectFile(f) {
  document.querySelectorAll('.ftab').forEach(t=>t.classList.remove('active'));
  document.getElementById('ft-'+f).classList.add('active');
}

/* ── GENERATE FILES ── */
function generateFiles() {
  // Collect final values
  state.sburl  = document.getElementById('f-sburl').value.trim();
  state.sbanon = document.getElementById('f-sbanon').value.trim();
  state.admin  = document.getElementById('f-admin').value.trim();
  state.apikey = document.getElementById('f-apikey').value.trim();
  state.cakto  = document.getElementById('f-cakto').value.trim() || 'https://pay.cakto.com.br/SEU-LINK';
  state.wa     = document.getElementById('f-wa').value.trim().replace(/\D/g,'');
  state.pass   = document.getElementById('f-pass1').value;

  if (!state.sburl || !state.sbanon || !state.admin || !state.apikey || !state.wa) {
    showToast('⚠️ Preencha todos os campos obrigatórios antes de gerar.');
    return;
  }

  const btn = document.getElementById('btn-gen');
  btn.innerHTML = '<span class="spinner"></span> Gerando arquivos…';
  btn.disabled = true;

  setTimeout(() => {
    buildMainFile();
    buildAdminFile();
    state.mainGenerated = true;
    state.adminGenerated = true;

    btn.innerHTML = '✅ Arquivos gerados com sucesso!';
    btn.style.background = 'var(--green)';

    document.getElementById('btn-dl-main').style.display = 'inline-flex';
    document.getElementById('btn-dl-admin').style.display = 'inline-flex';

    document.getElementById('gen-area').innerHTML = `
      <div style="text-align:center">
        <div style="font-size:32px;margin-bottom:8px">🎉</div>
        <div style="font-size:14px;font-weight:700;color:var(--ink2);margin-bottom:4px">Arquivos gerados!</div>
        <div style="font-size:12px;color:var(--muted)">Baixe os 2 arquivos abaixo e siga os passos de deploy.</div>
      </div>
    `;
    markDone(6);
    showToast('✅ plania.html e plania-admin.html prontos para baixar!');
    updateSummary();
  }, 800);
}

/* ── BUILD plania.html ── */
function buildMainFile() {
  // Template is embedded here — we replace the config lines
  const template = getMainTemplate();
  state.mainContent = template
    .replace(/const API_KEY\s*=\s*["'][^"']*["'];/, `const API_KEY        = "${state.apikey}";`)
    .replace(/const SB_URL\s*=\s*["'][^"']*["'];/, `const SB_URL         = "${state.sburl}";`)
    .replace(/const SB_ANON\s*=\s*["'][^"']*["'];/, `const SB_ANON        = "${state.sbanon}";`)
    .replace(/const CAKTO_LINK\s*=\s*["'][^"']*["'];/, `const CAKTO_LINK     = "${state.cakto}";`)
    .replace(/const WHATSAPP_NUM\s*=\s*["'][^"']*["'];/, `const WHATSAPP_NUM   = "${state.wa}";`);
}

/* ── BUILD plania-admin.html ── */
function buildAdminFile() {
  const template = getAdminTemplate();
  state.adminContent = template
    .replace(/const SB_URL\s*=\s*["'][^"']*["'];/, `const SB_URL      = "${state.sburl}";`)
    .replace(/const SB_ANON\s*=\s*["'][^"']*["'];/, `const SB_ANON     = "${state.sbanon}";`)
    .replace(/const ADMIN_EMAIL\s*=\s*["'][^"']*["'];/, `const ADMIN_EMAIL = "${state.admin}";`);
}

/* ── DOWNLOAD ── */
function downloadMain() {
  if (!state.mainContent) { showToast('⚠️ Gere os arquivos primeiro.'); return }
  dl('plania.html', state.mainContent);
}

function downloadAdmin() {
  if (!state.adminContent) { showToast('⚠️ Gere os arquivos primeiro.'); return }
  dl('plania-admin.html', state.adminContent);
}

function dl(name, content) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([content], {type:'text/html;charset=utf-8'}));
  a.download = name; a.click();
  showToast(`↓ Baixando ${name}…`);
}

/* ── COPY SQL ── */
function copySQL() {
  const sql = document.getElementById('sql-code').textContent;
  navigator.clipboard.writeText(sql).then(() => showToast('📋 SQL copiado! Cole no SQL Editor do Supabase.'));
}

/* ── TOAST ── */
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.style.display = 'block';
  setTimeout(() => { t.style.display = 'none' }, 3500);
}

/* ── TEMPLATES ── */
// These load the actual file contents from sessionStorage if available,
// or use placeholder templates that the user downloads and edits.
function getMainTemplate() {
  return sessionStorage.getItem('plania_main') || MAIN_PLACEHOLDER;
}
function getAdminTemplate() {
  return sessionStorage.getItem('plania_admin') || ADMIN_PLACEHOLDER;
}

// Minimal placeholder if files aren't pre-loaded
const MAIN_PLACEHOLDER = `<!-- plania.html — Configure as linhas abaixo -->
<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="UTF-8"/><title>PlanIA</title></head>
<body>
<script>
/* CONFIG */
const API_KEY        = "CONFIGURAR";
const SB_URL         = "CONFIGURAR";
const SB_ANON        = "CONFIGURAR";
const CAKTO_LINK     = "CONFIGURAR";
const WHATSAPP_NUM   = "CONFIGURAR";
/* Baixe o arquivo plania.html completo do Claude e use este configurador */
<\/script>
</body>
</html>`;

const ADMIN_PLACEHOLDER = `<!-- plania-admin.html — Configure as linhas abaixo -->
<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="UTF-8"/><title>PlanIA Admin</title></head>
<body>
<script>
const SB_URL      = "CONFIGURAR";
const SB_ANON     = "CONFIGURAR";
const ADMIN_EMAIL = "CONFIGURAR";
/* Baixe o arquivo plania-admin.html completo do Claude e use este configurador */
<\/script>
</body>
</html>`;

/* ── LOAD FILE CONTENTS ── */
// Instructions for user to load their actual files
window.addEventListener('load', () => {
  // Check if running with actual files
  const hasMain  = sessionStorage.getItem('plania_main');
  const hasAdmin = sessionStorage.getItem('plania_admin');
  if (!hasMain || !hasAdmin) {
    injectFileLoader();
  }
});

function injectFileLoader() {
  const notice = document.createElement('div');
  notice.style.cssText = 'background:var(--bbg);border:1px solid var(--bbd);border-radius:12px;padding:16px;margin-bottom:16px;font-size:12px;color:var(--blue)';
  notice.innerHTML = `
    <div style="font-weight:700;margin-bottom:8px">📂 Carregar seus arquivos PlanIA</div>
    <div style="color:var(--muted);margin-bottom:10px">Para que o configurador insira suas chaves corretamente nos arquivos completos, carregue os arquivos baixados do Claude:</div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <label style="background:var(--ink);color:#fff;padding:8px 16px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px">
        📄 Carregar plania.html
        <input type="file" accept=".html" onchange="loadFile(event,'main')" style="display:none"/>
      </label>
      <label style="background:var(--ink);color:#fff;padding:8px 16px;border-radius:8px;cursor:pointer;font-weight:600;font-size:12px">
        🔐 Carregar plania-admin.html
        <input type="file" accept=".html" onchange="loadFile(event,'admin')" style="display:none"/>
      </label>
    </div>
    <div id="file-status" style="margin-top:8px;font-size:11px;color:var(--muted)">Aguardando os arquivos…</div>
  `;
  const page = document.querySelector('.page');
  const firstSection = document.getElementById('sec-1');
  page.insertBefore(notice, firstSection);
}

function loadFile(event, type) {
  const file = event.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    sessionStorage.setItem('plania_'+type, e.target.result);
    const status = document.getElementById('file-status');
    const mainOk  = sessionStorage.getItem('plania_main');
    const adminOk = sessionStorage.getItem('plania_admin');
    if (mainOk && adminOk) {
      status.innerHTML = '✅ Ambos os arquivos carregados! Agora preencha as configurações abaixo.';
      status.style.color = 'var(--green)';
    } else {
      const faltando = mainOk ? 'plania-admin.html' : 'plania.html';
      status.innerHTML = `✅ ${file.name} carregado! Falta: ${faltando}`;
      status.style.color = 'var(--amber)';
    }
    showToast('✅ '+file.name+' carregado!');
  };
  reader.readAsText(file);
}
</script>
</body>
</html>
